# REZ Conversation Intelligence Service

# Server
PORT=4008
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_conversation_intelligence

# Redis
REDIS_URL=redis://localhost:6379

# Internal Service Auth
INTERNAL_SERVICE_TOKENS_JSON={"intent-graph":"token1","payment":"token2","auth":"token3"}

# Logging
LOG_LEVEL=info

# ML/NLP Settings
SENTIMENT_MODEL=afinn
INTENT_CONFIDENCE_THRESHOLD=0.7
SENTIMENT_CONFIDENCE_THRESHOLD=0.6

# Export Settings
EXPORT_BATCH_SIZE=1000
EXPORT_INTERVAL_HOURS=24
MODEL_VERSION_PREFIX=v

# Queue Settings
QUEUE_CONCURRENCY=5
JOB_TIMEOUT_MS=300000

# External Services
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Feature Flags
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_INTENT_EXTRACTION=true
ENABLE_OUTCOME_TRACKING=true
