# REZ Temporal Intelligence Service - Environment Variables

# Service Configuration
PORT=4135
NODE_ENV=development
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-temporal-intelligence

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token
API_KEYS=key1,key2,key3

# External Services
REZ_INTELLIGENCE_URL=http://localhost:4018
REZ_INTELLIGENCE_API_KEY=your-api-key

# Feature Flags
ENABLE_MARKOV_CHAIN=true
ENABLE_FOURIER_ANALYSIS=true
ENABLE_SESSION_SEGMENTATION=true

# Cache TTL (seconds)
CACHE_TTL_SEQUENCE=3600
CACHE_TTL_PATTERN=7200
CACHE_TTL_PREDICTION=1800
