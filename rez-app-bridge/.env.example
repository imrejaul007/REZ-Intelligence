# Server Configuration
PORT=4089

# Orchestrator Service
ORCHESTRATOR_URL=http://localhost:4006

# Firebase Cloud Messaging
FCM_PROJECT_ID=your-firebase-project-id
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# App Authentication
APP_API_KEY=your-secure-api-key-for-app-auth

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"app-bridge":"internal-service-token"}

# MongoDB (optional - for device tokens and message history)
MONGODB_URI=mongodb://localhost:27017/rez-app-bridge

# Redis (for Socket.IO adapter and caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
