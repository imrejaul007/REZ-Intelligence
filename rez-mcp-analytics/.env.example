# =============================================================================
# REZ Analytics MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Analytics Service URL
ANALYTICS_SERVICE_URL=https://rez-analytics-service.onrender.com

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real analytics API calls
USE_REAL_ANALYTICS=false
