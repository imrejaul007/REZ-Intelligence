# =============================================================================
# REZ Agent Invoke MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Agent Orchestrator URL
AGENT_ORCHESTRATOR_URL=http://localhost:4062

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real agent API calls
USE_REAL_AGENTS=false

# =============================================================================
# AGENT ENDPOINTS (Optional - override defaults)
# =============================================================================

REORDER_ENGINE_URL=http://localhost:4040
DEMAND_FORECAST_URL=http://localhost:4042
PRICE_OPTIMIZER_URL=http://localhost:4043
