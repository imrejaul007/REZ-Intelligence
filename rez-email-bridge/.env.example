# REZ Email Bridge - Environment Configuration

# Server
NODE_ENV=development
PORT=4086
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# SMTP Configuration (Primary)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@rez.in

# SendGrid (Backup)
SENDGRID_API_KEY=

# Internal Services
ORCHESTRATOR_URL=http://localhost:4006
INTERNAL_SERVICE_TOKENS_JSON={"orchestrator":"orchestrator-token","email-bridge":"email-bridge-token"}
INTERNAL_TOKEN=email-bridge-token
