# Environment Configuration
PORT=4061
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_automotive_mind

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
INTERNAL_TOKEN=your-internal-api-token-change-in-production

# RABTUL Integration
RABTUL_API_KEY=your-rabtul-api-key
RABTUL_BASE_URL=https://api.rabtul.io

# AI Settings
AI_MODEL=claude-3-sonnet
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AI=30
RATE_LIMIT_MAX_READ=100