{
  "name": "@rez/unified-agent-sdk",
  "version": "1.0.0",
  "description": "Unified SDK for ReZ AI agents to connect to commerce services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./connectors": {
      "types": "./dist/connectors/index.d.ts",
      "import": "./dist/connectors/index.mjs",
      "require": "./dist/connectors/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.mjs",
      "require": "./dist/events/index.js"
    }
  },
  "scripts": {
    "build": "tsup && npm run build:dts && npm run move:dts",
    "build:dts": "tsc --project tsconfig.json --emitDeclarationOnly --outDir dist",
    "move:dts": "mv dist/src/* dist/ && rmdir dist/src",
    "dev": "tsup --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rez",
    "agent",
    "sdk",
    "commerce",
    "payment",
    "wallet",
    "unified"
  ],
  "author": "ReZ Platform Team",
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "eventemitter3": "^5.0.0",
    "opossum": "^8.1.0",
    "retry": "^0.13.1",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/opossum": "^8.1.9",
    "@types/retry": "^0.12.5",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
