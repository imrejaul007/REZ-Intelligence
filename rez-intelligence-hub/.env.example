# ── ReZ Intelligence Hub - Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values

# ── Environment ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Server Port ────────────────────────────────────────────────────────────────
PORT=4020

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string for MongoDB Atlas
MONGODB_URI=mongodb+srv://work_db_user:<YOUR_PASSWORD>@rez-intent-graph.a8ilqgi.mongodb.net/rez-intelligence

# ── Redis (Optional) ───────────────────────────────────────────────────────────
# For distributed caching across service instances
# Required for production: enables Redis caching layer
REDIS_URL=redis://localhost:6379

# ── AI/ML APIs ────────────────────────────────────────────────────────────────
# Anthropic API for advanced AI processing
ANTHROPIC_API_KEY=

# OpenAI API for embeddings and analysis
OPENAI_API_KEY=

# ── Authentication ─────────────────────────────────────────────────────────────
# Internal service token for server-to-server auth
# Must match across all ReZ ecosystem services
INTERNAL_SERVICE_TOKEN=change-me-to-a-secure-random-string

# ── CORS (Optional) ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ────────────────────────────────────────────────────────────────────
# Set to 'debug' for verbose logging in development
LOG_LEVEL=info

# ── External Service URLs ───────────────────────────────────────────────────────
# Override individual services here if they differ from defaults

# Core ReZ Services
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
MONOLITH_URL=https://rez-backend.onrender.com
ORDER_SERVICE_URL=https://rez-order-service.onrender.com
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com

# Intent Graph (for signal enrichment)
INTENT_GRAPH_URL=https://rez-intent-graph.onrender.com

# Analytics
ANALYTICS_SERVICE_URL=https://analytics-events.onrender.com

# Finance
FINANCE_SERVICE_URL=http://localhost:4006

# ── Observability & Monitoring ───────────────────────────────────────────────────

# Service name for logging and metrics
SERVICE_NAME=intelligence-hub

# Sentry Error Tracking
# Get your DSN from https://sentry.io
# Leave empty to disable Sentry
SENTRY_DSN=
