# REZ ML Observability - Environment Variables
NODE_ENV=production
PORT=4130

# Database for metrics
MONGODB_URI=mongodb://localhost:27017/rez_ml_observability

# Alerting
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=ml-team@rez.money

# Drift Detection
DRIFT_CHECK_INTERVAL_MINUTES=5
PSI_WARNING_THRESHOLD=0.1
PSI_CRITICAL_THRESHOLD=0.25

# Internal Token
INTERNAL_SERVICE_TOKEN=your-internal-token
