# REZ Error Intelligence Service - Environment Configuration

# ============================================
# REQUIRED VARIABLES
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/rez-error-intelligence

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Service name for logging
SERVICE_NAME=rez-error-intelligence

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Port (default: 4005)
PORT=4005

# Node environment (development, production)
NODE_ENV=development
