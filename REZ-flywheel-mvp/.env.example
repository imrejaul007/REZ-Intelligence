# REZ Flywheel MVP - Environment Configuration

# ============================================
# REQUIRED VARIABLES
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/rez-flywheel-mvp

# Internal service authentication token (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Service name for logging
SERVICE_NAME=rez-flywheel-mvp

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Port (default: 4101)
PORT=4101

# Node environment (development, production)
NODE_ENV=development
