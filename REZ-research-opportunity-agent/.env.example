# Service Configuration
PORT=4058
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-research-agent

# Redis Configuration
REDIS_URL=redis://localhost:6379

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Logging
LOG_LEVEL=info

# Worker Schedules (cron expressions)
DAILY_SCHEDULE=0 6 * * *
WEEKLY_SCHEDULE=0 7 * * 1
REALTIME_INTERVAL=300000

# Security
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# CORS (optional)
CORS_ORIGIN=*

# External Services (optional)
# REZ_INSIGHTS_SERVICE_URL=http://localhost:3000
# REZ_CAMPAIGN_BUILDER_URL=http://localhost:4009
