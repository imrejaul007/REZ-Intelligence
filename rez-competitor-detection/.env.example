# REZ Competitor Detection Service Environment Configuration

# Server
PORT=4059
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-competitor-detection

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
INTERNAL_SERVICE_TOKEN=your-secure-token-here
INTERNAL_SERVICE_TOKENS_JSON={}

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Service URLs
REZ_MIND_ENDPOINT=https://rezmind.rezapp.com
REZ_MIND_API_KEY=your-api-key

# Analytics
SENTRY_DSN=https://xxx@sentry.io/xxx

# Logging
LOG_LEVEL=info
