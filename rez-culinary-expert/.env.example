# =============================================================================
# REZ Culinary Expert Agent - Environment Configuration
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rez_culinary

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Anthropic API (for AI-powered responses)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Service-to-Service Authentication
# JSON map of service tokens: {"service-name":"token"}
INTERNAL_SERVICE_TOKENS_JSON={"rez-intent-graph":"your-token-here"}

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: External Services
# ORDER_SERVICE_URL=http://localhost:4003
# NOTIFICATION_SERVICE_URL=http://localhost:4004
