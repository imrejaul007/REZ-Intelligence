# REZ Workflow Builder - Environment Configuration
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=4199

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-workflow-builder
MONGODB_USER=
MONGODB_PASSWORD=

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
# Comma-separated list of valid API keys
API_KEYS=your-api-key-here

# Comma-separated list of valid internal service tokens
INTERNAL_TOKENS=your-internal-token-here

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://rez.example.com

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
