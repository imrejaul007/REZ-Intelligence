# Environment variables for REZ Action Engine
# Copy to .env and configure

# Service Configuration
PORT=4009
NODE_ENV=development

# Redis
REDIS_URL=redis://default:password@localhost:6379

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-action-engine

# Event Platform (REZ Event Platform)
EVENT_PLATFORM_HOST=localhost
EVENT_PLATFORM_PORT=4001
EVENT_PLATFORM_API_KEY=

# NextaBiZ Integration
NEXTABIZ_API_URL=http://localhost:4002
NEXTABIZ_API_KEY=

# Finance Service
FINANCE_SERVICE_URL=http://localhost:4006

# Push Service (Notifications)
PUSH_SERVICE_URL=http://localhost:3005

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
