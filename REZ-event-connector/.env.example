# REZ Event Connector Configuration

# Server
PORT=4052
NODE_ENV=development
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_event_connector

# Redis
REDIS_URL=redis://localhost:6379

# Service URLs
IDENTITY_GRAPH_URL=http://localhost:4050
MEMORY_ENGINE_URL=http://localhost:4051
EVENT_PLATFORM_URL=http://localhost:4053

# Authentication (must match other services)
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-here

# Circuit Breaker Configuration
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000

# Event Polling Configuration
EVENT_BATCH_SIZE=100
EVENT_POLL_INTERVAL=5000
