{
  "name": "rez-aggregator-hub",
  "version": "1.0.0",
  "description": "Unified interface for Swiggy, Zomato, and Magicpin restaurant aggregator integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "docs": "typedoc"
  },
  "keywords": [
    "swiggy",
    "zomato",
    "magicpin",
    "restaurant",
    "food-delivery",
    "aggregator",
    "pos",
    "ordering"
  ],
  "author": "ReZ Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {},
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typedoc": "^0.25.8",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rez/aggregator-hub"
  },
  "bugs": {
    "url": "https://github.com/rez/aggregator-hub/issues"
  }
}
