# REZ Intelligence Integration Tests Environment Variables

# Service URLs (defaults are for local development)
ORCHESTRATOR_URL=http://localhost:4070
CONTEXT_ENGINE_URL=http://localhost:4071
CORE_BRAIN_URL=http://localhost:4072
AGENT_REGISTRY_URL=http://localhost:4073
HOSPITALITY_EXPERT_URL=http://localhost:3000
CULINARY_EXPERT_URL=http://localhost:3001

# Internal service token for service-to-service communication
# This should match the INTERNAL_SERVICE_TOKENS_JSON in your services
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# Optional: Enable debug logging
DEBUG=0

# Optional: Override test timeout (default: 30000ms)
# JEST_TIMEOUT=60000
