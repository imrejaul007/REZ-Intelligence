{
  "name": "@rez/integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for REZ Intelligence services",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "build": "tsc"
  },
  "keywords": [
    "rez",
    "intelligence",
    "integration-tests"
  ],
  "author": "REZ Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "wait-on": "^7.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "moduleNameMapper": {
      "^@rez/shared-types$": "<rootDir>/../shared-types/src"
    },
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.ts"]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
