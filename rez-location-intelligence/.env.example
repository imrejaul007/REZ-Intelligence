# REZ Location Intelligence Service

# Server
PORT=4040
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-location-intelligence

# Authentication (Internal Service Token)
INTERNAL_SERVICE_TOKEN=your-secret-token-here
INTERNAL_SERVICE_TOKENS_JSON={}

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Service Discovery
SERVICE_NAME=rez-location-intelligence
SERVICE_VERSION=1.0.0
