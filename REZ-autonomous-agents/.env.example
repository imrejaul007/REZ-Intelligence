# REZ Autonomous Agents - Environment Configuration

# ============================================
# REQUIRED VARIABLES
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/rez-autonomous-agents

# Redis URL for caching and pub/sub
REDIS_URL=redis://localhost:6379

# Internal service token for authentication (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Service name for logging
SERVICE_NAME=rez-autonomous-agents

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Port (default: 4062)
PORT=4062

# Node environment (development, production)
NODE_ENV=development
