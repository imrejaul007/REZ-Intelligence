{
  "name": "rez-health-monitor",
  "version": "2.0.0",
  "description": "Production health monitoring service for REZ Intelligence platform - monitors all services, tracks dependencies, and provides alerts with circuit breaker support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@rez/logger": "file:../packages/rez-logger",
    "@rez/security-middleware": "file:../packages/rez-security-middleware",
    "@rez/shared-types": "file:../packages/rez-shared-types",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "health",
    "monitoring",
    "circuit-breaker",
    "microservices",
    "alerts",
    "rez"
  ],
  "author": "REZ Team",
  "license": "MIT"
}
