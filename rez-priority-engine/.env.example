# Environment Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
PORT=4080

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-priority-engine

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
INTERNAL_SERVICE_TOKENS_JSON={"payment-service":"secret-token-1","wallet-service":"secret-token-2","order-service":"secret-token-3"}

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache
CACHE_TTL_SECONDS=300

# Processing
EMERGENCY_TIMEOUT_MS=1000
PRIORITY_PROCESSING_INTERVAL_MS=100
