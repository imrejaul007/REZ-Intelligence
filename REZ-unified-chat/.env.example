# REZ Agent OS - Environment Variables
# Connects to ALL intelligence services

# Server
PORT=4100

# ============ INTELLIGENCE SERVICES ============

# Intent Graph (User intent detection)
REZ_INTENT_GRAPH_URL=http://localhost:4050

# Memory Engine (User context/history)
REZ_MEMORY_URL=http://localhost:4051

# Identity Graph (Cross-app user identity)
REZ_IDENTITY_URL=http://localhost:4050

# Taste Profile (User preferences)
REZ_TASTE_URL=http://localhost:4041

# Reorder Engine (Purchase predictions)
REZ_REORDER_URL=http://localhost:4040

# Demand Forecast
REZ_DEMAND_URL=http://localhost:4042

# Autonomous Agents (30 AI agents)
REZ_AGENTS_URL=http://localhost:4062

# Event Platform (Logging)
REZ_EVENT_URL=http://localhost:4008

# CDP Service (Customer Data Platform)
REZ_CDP_URL=http://localhost:3005

# ============ BUSINESS SERVICES ============

# Order Service
ORDER_SERVICE_URL=https://rez-order.onrender.com

# Booking Service
BOOKING_SERVICE_URL=https://rez-booking.onrender.com

# Wallet Service
WALLET_SERVICE_URL=https://rez-wallet.onrender.com

# Search Service
SEARCH_SERVICE_URL=https://rez-search.onrender.com

# Support Copilot (Child of Agent OS)
SUPPORT_URL=http://localhost:4033

# Knowledge Base
KNOWLEDGE_URL=https://rez-knowledge.onrender.com
