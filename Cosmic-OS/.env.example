# Cosmic OS - Environment Variables

# ============================================
# SERVICE CONFIGURATION
# ============================================

PORT=4163
NODE_ENV=development

# ============================================
# MONGODB
# ============================================

MONGODB_URI=mongodb://localhost:27017/cosmic_os

# ============================================
# RABTUL SERVICES (Production URLs)
# ============================================

# Auth Service
RABTUL_AUTH_URL=https://rez-auth-service.onrender.com

# Wallet Service
RABTUL_WALLET_URL=https://rez-wallet-service-36vo.onrender.com

# Notification Service
RABTUL_NOTIFICATION_URL=https://rez-notifications-service.onrender.com

# Profile Service
RABTUL_PROFILE_URL=https://rez-profile-service.onrender.com

# Gamification Service
RABTUL_GAMIFICATION_URL=http://localhost:4041

# Prive (Premium Loyalty)
RABTUL_PRIVE_URL=http://localhost:4070

# ============================================
# INTERNAL SERVICES
# ============================================

# REZ Intelligence Services
INTERNAL_SERVICE_TOKEN=cosmic-os-secret-token-change-in-production

# Emotional Intelligence Service
EMOTIONAL_SERVICE_URL=http://localhost:4160

# Life Pattern Engine
LIFE_PATTERN_SERVICE_URL=http://localhost:4161

# Human Context Graph
HUMAN_CONTEXT_URL=http://localhost:4162

# Signal Aggregator
SIGNAL_AGGREGATOR_URL=http://localhost:4142

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
