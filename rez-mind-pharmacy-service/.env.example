# Server Configuration
PORT=4070
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_mind_pharmacy

# RABTUL SDK Service URLs
AUTH_SERVICE_URL=http://localhost:4002
WALLET_SERVICE_URL=http://localhost:4003
NOTIFICATION_SERVICE_URL=http://localhost:4004
INTENT_SERVICE_URL=http://localhost:4006
CUSTOMER_PROFILE_SERVICE_URL=http://localhost:4010

# API Gateway
API_GATEWAY_URL=http://localhost:4000

# Authentication
INTERNAL_SERVICE_TOKEN=your-secure-internal-service-token-here
JWT_SECRET=your-jwt-secret-here

# RABTUL SDK Configuration
RABTUL_SDK_API_KEY=your-api-key-here
RABTUL_SDK_TIMEOUT=30000
RABTUL_SDK_RETRIES=3

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AI=30
RATE_LIMIT_MAX_READ=100

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Drug Database Configuration
DRUG_DATABASE_UPDATE_INTERVAL=86400000