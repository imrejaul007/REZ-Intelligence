  "description": "REZ Purpose-Built Fitness Expert Agent for workout planning, fitness recommendations, and progress tracking",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
