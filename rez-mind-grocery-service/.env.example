# Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=4057
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rez_mind_grocery

# Authentication
INTERNAL_SERVICE_TOKEN=your-32-character-minimum-secret-token-here
AUTH_SERVICE_URL=https://auth.rez.com

# Logging
LOG_LEVEL=info

# Rate Limiting (milliseconds)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AI=30
RATE_LIMIT_MAX_READ=100

# Integration URLs
RABTUL_PLATFORM_URL=https://rabtul.rez.com
REZ_INTELLIGENCE_HUB_URL=https://hub.rez.com