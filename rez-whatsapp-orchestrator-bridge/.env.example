# REZ WhatsApp Orchestrator Bridge - Environment Configuration
# Bridges WhatsApp Business API with the orchestration engine

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=4080
BRIDGE_PORT=4080
SERVICE_NAME=rez-whatsapp-orchestrator-bridge
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_whatsapp_bridge

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Service URLs
# =============================================================================
ORCHESTRATOR_URL=http://localhost:4070
CORE_BRAIN_URL=http://localhost:4072

# =============================================================================
# Internal Service Authentication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-orchestrator-v2":"dev-token","rez-core-brain":"dev-token"}

# =============================================================================
# WhatsApp Business API Configuration
# =============================================================================
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token-here
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_here
WHATSAPP_APP_SECRET=your-app-secret-here

# =============================================================================
# Twilio Configuration (for fallback)
# =============================================================================
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here

# =============================================================================
# Bridge Settings
# =============================================================================
SESSION_TTL_SECONDS=86400
MAX_RETRIES=3
RETRY_DELAY_MS=1000
PROCESSING_INTERVAL_MS=500
MAX_QUEUE_SIZE=1000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,https://rez.money

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ROUTE=/health
