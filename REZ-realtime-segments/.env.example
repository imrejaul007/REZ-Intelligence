# Server
PORT=4040
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=300

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-realtime-segments

# Service Auth
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here
INTERNAL_SERVICE_TOKENS_JSON={}

# Webhook Configuration
WEBHOOK_ENDPOINTS=["http://localhost:4004/api/webhooks/segment-events"]

# External Services
REZ_INTENT_GRAPH_URL=http://localhost:4007
REZ_ATTRIBUTION_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
