# Service Configuration
PORT=4110
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=ab-testing

# Database
MONGODB_URI=mongodb://localhost:27017/rez-ab-testing

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379

# Security
INTERNAL_SERVICE_TOKEN=your-secure-token-here
INTERNAL_SERVICE_TOKENS_JSON={"service-name":"token"}

# Observability
SENTRY_DSN=

# Experiment Settings
DEFAULT_CONFIDENCE_LEVEL=0.95
