# =============================================================================
# REZ Inventory Intelligence Service Configuration
# =============================================================================

# Server Configuration
PORT=4035
NODE_ENV=development
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_inventory_intelligence

# Redis Configuration (optional - for caching)
REDIS_URL=redis://localhost:6379

# Internal Service Token (REQUIRED in production)
INTERNAL_SERVICE_TOKEN=your-secure-token-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# External Service URLs
# =============================================================================
ORDER_SERVICE_URL=http://localhost:4003
AUTH_SERVICE_URL=http://localhost:3000
INVENTORY_SERVICE_URL=http://localhost:4010
ANALYTICS_SERVICE_URL=http://localhost:4006

# =============================================================================
# Forecasting Configuration
# =============================================================================
# Number of days of historical data to use for forecasting
FORECAST_HISTORY_DAYS=90

# Number of weeks to analyze for seasonality detection
FORECAST_SEASONALITY_WEEKS=12

# Default confidence level for prediction intervals (0.01 to 0.99)
FORECAST_CONFIDENCE_LEVEL=0.95

# =============================================================================
# Optimization Configuration
# =============================================================================
# Service level for safety stock calculation (probability of not stocking out)
SAFETY_STOCK_SERVICE_LEVEL=0.95

# Service level for reorder point calculation
REORDER_POINT_SERVICE_LEVEL=0.90

# Target inventory turns per year
DEFAULT_TARGET_TURNS=12

# Annual holding cost as percentage of unit cost
DEFAULT_HOLDING_COST_PERCENT=25

# Cost per order placement
DEFAULT_ORDER_COST=50

# =============================================================================
# Inventory Thresholds
# =============================================================================
LOW_STOCK_THRESHOLD=10
CRITICAL_STOCK_THRESHOLD=5
FORECAST_DAYS=30
VELOCITY_WINDOW_DAYS=7
