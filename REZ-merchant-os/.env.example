# Service Configuration
PORT=4073
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=merchant-os

# Database
MONGODB_URI=mongodb://localhost:27017/rez-merchant-os

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# Security
INTERNAL_SERVICE_TOKEN=your-secure-token-here
INTERNAL_SERVICE_TOKENS_JSON={"service-name":"token"}

# Observability
SENTRY_DSN=

# AI Integration (optional)
OPENAI_API_KEY=
