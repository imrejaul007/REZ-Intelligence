# REZ Multilingual - Environment Configuration
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=4150

# Authentication
API_KEYS=your-api-key-here
INTERNAL_TOKENS=your-internal-token-here

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://rez.example.com

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ML Service (optional - falls back to rule-based)
ML_SERVICE_URL=http://localhost:4080
