# REZ Hospitality Expert Agent Configuration

# Server Configuration
PORT=3015
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=rez_hospitality

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# Service Configuration
SERVICE_NAME=rez-hospitality-expert
LOG_LEVEL=info

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"rez-mind":"your-internal-token-here"}

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT_MS=1800000
MAX_CONVERSATION_HISTORY=50

# Hotel Property Configuration (Example)
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=en
TIMEZONE=America/New_York
