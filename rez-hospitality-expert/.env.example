# REZ Hospitality Expert Agent - Environment Configuration
# Expert agent for hotel, restaurant, and travel hospitality services

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3000
HOSPITALITY_PORT=3000
SERVICE_NAME=rez-hospitality-expert
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_hospitality

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Service URLs
# =============================================================================
CORE_BRAIN_URL=http://localhost:4072
ORCHESTRATOR_URL=http://localhost:4070

# =============================================================================
# Internal Service Authentication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-core-brain":"dev-token","rez-orchestrator-v2":"dev-token"}

# =============================================================================
# AI Configuration
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# =============================================================================
# Expert Configuration
# =============================================================================
EXPERT_NAME=hospitality
EXPERT_VERSION=1.0.0
EXPERT_TIMEOUT_MS=30000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Session Configuration
# =============================================================================
SESSION_TIMEOUT_MS=1800000
MAX_CONVERSATION_HISTORY=50

# =============================================================================
# Hotel Property Configuration
# =============================================================================
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=en
TIMEZONE=America/New_York

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4070

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ROUTE=/health
