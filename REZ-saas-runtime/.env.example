# REZ SaaS Runtime Configuration

# Service Port
PORT=4220
NODE_ENV=development

# Internal Service Token
INTERNAL_SERVICE_TOKEN=rez-saas-internal-token-change-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://rez.money,https://admin.rez.money

# RABTUL Payment Service
PAYMENT_SERVICE_URL=http://localhost:4001

# RABTUL Auth Service
AUTH_SERVICE_URL=http://localhost:4002

# RABTUL Wallet Service
WALLET_SERVICE_URL=http://localhost:4004

# Tenant Adapter
TENANT_ADAPTER_URL=http://localhost:4210

# API Gateway
API_GATEWAY_URL=http://localhost:4300

# Billing
BILLING_ENABLED=true
DEFAULT_PLAN=free
