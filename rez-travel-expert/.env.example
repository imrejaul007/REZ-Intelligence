# REZ Travel Expert Agent - Environment Configuration
# Expert agent for travel, booking, and transportation services

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=3003
TRAVEL_PORT=3003
SERVICE_NAME=rez-travel-expert
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_travel

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Service URLs
# =============================================================================
CORE_BRAIN_URL=http://localhost:4072
ORCHESTRATOR_URL=http://localhost:4070
HOTEL_SERVICE_URL=http://localhost:4003
TRANSPORT_SERVICE_URL=http://localhost:4004
BOOKING_SERVICE_URL=http://localhost:4005

# =============================================================================
# Internal Service Authentication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-core-brain":"dev-token","rez-orchestrator-v2":"dev-token"}

# =============================================================================
# AI Configuration
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# =============================================================================
# Expert Configuration
# =============================================================================
EXPERT_NAME=travel
EXPERT_VERSION=1.0.0
EXPERT_TIMEOUT_MS=30000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Session Configuration
# =============================================================================
SESSION_TIMEOUT_MS=1800000
MAX_CONVERSATION_HISTORY=50

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4070

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ROUTE=/health
