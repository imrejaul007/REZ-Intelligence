# REZ Context Engine - Environment Configuration
# Manages conversation context and memory for AI agents

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=4071
CONTEXT_ENGINE_PORT=4071
SERVICE_NAME=rez-context-engine
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_context_engine

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=1

# =============================================================================
# Service URLs
# =============================================================================
CORE_BRAIN_URL=http://localhost:4072
ORCHESTRATOR_URL=http://localhost:4070

# =============================================================================
# Context Configuration
# =============================================================================
MAX_CONTEXT_TOKENS=4096
MAX_HISTORY_LENGTH=50
CONTEXT_TTL_SECONDS=3600
SESSION_TTL_SECONDS=1800

# =============================================================================
# Memory Configuration
# =============================================================================
SHORT_TERM_MEMORY_TTL=3600
LONG_TERM_MEMORY_RETENTION=30
MAX_SHORT_TERM_MEMORIES=100
EMBEDDING_MODEL=text-embedding-ada-002

# =============================================================================
# Internal Service Authentication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-core-brain":"dev-token","rez-orchestrator-v2":"dev-token"}

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4070,http://localhost:4072

# =============================================================================
# AI Configuration (Optional)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ROUTE=/health
