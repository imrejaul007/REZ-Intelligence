# Server
PORT=4085

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Backup SMS Provider (MSG91)
MSG91_API_KEY=your_msg91_api_key

# Orchestrator
ORCHESTRATOR_URL=http://localhost:4006

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"orchestrator":"your-orchestrator-token","payment":"your-payment-token"}

# Redis
REDIS_URL=redis://localhost:6379

# MongoDB (optional - for logging/audit)
MONGODB_URI=mongodb://localhost:27017/rez_sms_bridge
