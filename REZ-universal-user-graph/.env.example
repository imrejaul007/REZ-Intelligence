# Service Configuration
PORT=4055
NODE_ENV=development

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-universal-user-graph

# Internal Service Tokens (JSON map)
INTERNAL_SERVICE_TOKENS_JSON={"intent-graph":"token1","consumer-graph":"token2","cdp":"token3","wallet":"token4","support":"token5"}

# External Service Endpoints
INTENT_GRAPH_URL=http://localhost:4050
CONSUMER_GRAPH_URL=http://localhost:4051
CDP_URL=http://localhost:3005
WALLET_SERVICE_URL=http://localhost:4004
SUPPORT_SERVICE_URL=http://localhost:4003

# Graph Settings
GRAPH_MERGE_STRATEGY=weighted  # weighted, latest, or authoritative
IDENTITY_CONFIDENCE_THRESHOLD=0.85

# Cache Settings
CACHE_TTL_SECONDS=300
