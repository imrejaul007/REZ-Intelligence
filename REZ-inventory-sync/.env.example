# Service Configuration
PORT=4071
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=inventory-sync

# Database
MONGODB_URI=mongodb://localhost:27017/rez-inventory-sync

# Redis Cache
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# Security
INTERNAL_SERVICE_TOKEN=your-secure-token-here
INTERNAL_SERVICE_TOKENS_JSON={"service-name":"token"}

# Optional: Razorpay for payments (if needed)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Observability
SENTRY_DSN=

# Feature Flags
ENABLE_PREDICTIONS=true
