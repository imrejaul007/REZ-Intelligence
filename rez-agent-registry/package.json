{
  "name": "@rez/rez-agent-registry",
  "version": "1.0.0",
  "description": "REZ Agent Registry - Tracks and monitors all expert agents in the system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
