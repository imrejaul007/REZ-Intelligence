# REZ Agent Registry - Environment Configuration
# Central registry for agent discovery, health monitoring, and registration

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=4073
REGISTRY_PORT=4073
SERVICE_NAME=rez-agent-registry
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_agent_registry

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# Service URLs
# =============================================================================
CORE_BRAIN_URL=http://localhost:4072
ORCHESTRATOR_URL=http://localhost:4070

# =============================================================================
# Internal Service Authentication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-core-brain":"dev-token","rez-orchestrator-v2":"dev-token"}

# =============================================================================
# Registry Settings
# =============================================================================
HEARTBEAT_INTERVAL_MS=30000
HEARTBEAT_TTL_SECONDS=300
STALE_THRESHOLD_MS=120000

# =============================================================================
# Health Monitor Settings
# =============================================================================
HEALTH_CHECK_INTERVAL_SECONDS=60
HEALTH_CHECK_TIMEOUT_MS=5000
MAX_CONSECUTIVE_FAILURES=3
ENABLE_CRON_SCHEDULE=false
CRON_SCHEDULE=*/5 * * * *

# =============================================================================
# Agent Registration Settings
# =============================================================================
REGISTRATION_TIMEOUT_MS=10000
DEREGISTRATION_GRACE_PERIOD_MS=60000

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4070,http://localhost:4072

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ROUTE=/health
