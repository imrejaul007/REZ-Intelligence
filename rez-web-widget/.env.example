# Server Configuration
PORT=4088

# Orchestrator Service URL (for AI chat processing)
ORCHESTRATOR_URL=http://localhost:4006

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Internal Service Authentication
# JSON map of service tokens: {"service-name":"token"}
INTERNAL_SERVICE_TOKENS_JSON={"rez-web-widget":"your-widget-token"}

# Widget Configuration
WIDGET_PING_INTERVAL=25000
WIDGET_SESSION_TIMEOUT=3600000
WIDGET_MAX_MESSAGE_LENGTH=5000

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=https://yoursite.com,https://www.yoursite.com
