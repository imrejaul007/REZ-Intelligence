# REZ Unified CRM Hub - Environment Configuration
# Copy to .env for local development

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================

NODE_ENV=development
PORT=4100
MERCHANT_PORT=4101
SERVICE_NAME=rez-unified-crm-hub

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================

# Internal Service Token - for internal platform services
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-here

# Internal Service Tokens (JSON array for multiple services)
INTERNAL_SERVICE_TOKENS_JSON={"rez-platform":"token1","rez-analytics":"token2"}

# Merchant JWT Secret - for merchant authentication
# Generate with: openssl rand -hex 64
MERCHANT_JWT_SECRET=your-secure-merchant-jwt-secret-here-minimum-32-chars

# =============================================================================
# DATABASE
# =============================================================================

MONGODB_URI=mongodb://localhost:27017/rez-unified-crm-hub
MONGODB_USER=
MONGODB_PASSWORD=

# =============================================================================
# CACHE
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================================================
# REZ INTELLIGENCE SERVICES
# =============================================================================

IDENTITY_GRAPH_URL=http://localhost:4050
PREDICTIVE_ENGINE_URL=http://localhost:4059
RFM_SERVICE_URL=http://localhost:4055
UNIFIED_PROFILE_URL=http://localhost:4060
CUSTOMER_INTELLIGENCE_URL=http://localhost:4140
ENGAGEMENT_SCORER_URL=http://localhost:4065
INTENT_GRAPH_URL=http://localhost:4070

# =============================================================================
# REZ CONSUMER SERVICES
# =============================================================================

REZ_NOW_URL=http://localhost:3000
MERCHANT_SERVICE_URL=http://localhost:4005

# =============================================================================
# REZ MEDIA SERVICES
# =============================================================================

ENGAGEMENT_PLATFORM_URL=http://localhost:4017
CAMPAIGN_BUILDER_URL=http://localhost:4009

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

CRM_HUB_URL=http://localhost:4056

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Sentry (optional)
SENTRY_DSN=

# Log level: debug, info, warn, error
LOG_LEVEL=info
