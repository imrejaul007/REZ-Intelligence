# Server Configuration
PORT=3005
NODE_ENV=development
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_unified_engine
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
INTERNAL_SERVICE_TOKENS_JSON={"rez-agent-os":"agent-os-token","rez-intent-graph":"intent-graph-token","rez-cdp":"cdp-token","rez-merchant-os":"merchant-os-token","rez-commerce":"commerce-token"}

# WhatsApp (Twilio) Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+1234567890
WHATSAPP_WEBHOOK_SECRET=your-whatsapp-webhook-secret

# Voice (Twilio) Configuration
TWILIO_VOICE_FROM=+1234567890
VOICE_WEBHOOK_SECRET=your-voice-webhook-secret

# Copilot Configuration
COPILOT_WEBHOOK_SECRET=your-copilot-webhook-secret

# REZ Service URLs
REZ_AGENT_OS_URL=http://localhost:3001
REZ_INTENT_GRAPH_URL=http://localhost:3006
REZ_CDP_URL=http://localhost:3003
REZ_MERCHANT_OS_URL=http://localhost:3007
REZ_COMMERCE_URL=http://localhost:3008

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session TTL (in milliseconds)
SESSION_TTL_WHATSAPP=86400000
SESSION_TTL_VOICE=1800000
SESSION_TTL_COPILOT=1800000
SESSION_TTL_WEBSITE=7200000

# Performance Settings
MAX_CONCURRENT_SESSIONS=100000
MESSAGE_PROCESSING_TIMEOUT_MS=500
CONTEXT_AGGREGATION_TIMEOUT_MS=100

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
