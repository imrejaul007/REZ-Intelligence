# Server Configuration
PORT=3006
NODE_ENV=development
LOG_LEVEL=info

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-education

# Service-to-Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"rez-mind":"your-token-here","rez-payment":"your-token-here"}

# CORS Configuration
CORS_ORIGIN=*

# Agent Configuration
AGENT_NAME=rez-education-expert
AGENT_VERSION=1.0.0
