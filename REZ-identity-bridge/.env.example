# REZ Identity Bridge - Environment Configuration

# ============================================
# REQUIRED VARIABLES
# ============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/rez-identity-bridge

# Internal service token for authentication (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# Identity service URLs (required in production)
IDENTITY_GRAPH_URL=https://identity-graph-service.example.com
CONSUMER_GRAPH_URL=https://consumer-graph-service.example.com
CDP_URL=https://cdp-service.example.com

# ============================================
# OPTIONAL VARIABLES
# ============================================

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Service name for logging
SERVICE_NAME=rez-identity-bridge

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Port (default: 4092)
PORT=4092

# Node environment (development, production)
NODE_ENV=development
