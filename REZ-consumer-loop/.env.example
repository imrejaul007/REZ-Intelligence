# Service Configuration
PORT=3005
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=consumer-loop

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300

# Security
INTERNAL_SERVICE_TOKEN=your-secure-token-here
INTERNAL_SERVICE_TOKENS_JSON={"service-name":"token"}

# Service URLs
EVENT_PLATFORM_URL=http://localhost:3000
TASTE_PROFILE_SERVICE_URL=http://localhost:3001
MEMORY_ENGINE_URL=http://localhost:3002
INTENT_GRAPH_URL=http://localhost:4050
CONSUMER_GRAPH_URL=http://localhost:4051
