# Server Configuration
PORT=4087
NODE_ENV=development

# Jio RCS API Credentials
JIO_RCS_API_KEY=your_jio_api_key_here
JIO_RCS_API_SECRET=your_jio_api_secret_here
JIO_RCS_BASE_URL=https://api.jio.com/rcs/v1

# Airtel RCS API Credentials (Backup/Failover)
AIRTEL_RCS_API_KEY=your_airtel_api_key_here
AIRTEL_RCS_API_SECRET=your_airtel_api_secret_here
AIRTEL_RCS_BASE_URL=https://api.airtel.in/rcs/v1

# Service URLs
ORCHESTRATOR_URL=http://localhost:4006

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"orchestrator":"orchestrator_secret_token","payment":"payment_secret_token","notification":"notification_secret_token"}

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_rcs

# Logging
LOG_LEVEL=info
