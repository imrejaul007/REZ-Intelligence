# REZ Intelligence - Environment Variables Template
# Copy to .env and fill in values

# ============================================
# REQUIRED - All Services
# ============================================

# MongoDB Connection
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/rez_intelligence

# Redis Connection
REDIS_URL=redis://localhost:6379

# Internal Service Token (for service-to-service auth)
# Generate a strong random string: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=change-me-to-a-secure-random-string

# ============================================
# AI SERVICES - Optional
# ============================================

# Anthropic (Claude API) - for AI Router
ANTHROPIC_API_KEY=sk-ant-...
# For key rotation, comma-separated
ANTHROPIC_API_KEYS=sk-ant-key1,sk-ant-key2

# OpenAI - for AI Router
OPENAI_API_KEY=sk-...
# For key rotation, comma-separated
OPENAI_API_KEYS=sk-key1,sk-key2

# Google AI
GOOGLE_API_KEY=

# ============================================
# PAYMENT SERVICES
# ============================================

# Razorpay (for payments-brain)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ============================================
# EXTERNAL SERVICES
# ============================================

# Twilio (for voice AI)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ElevenLabs (for TTS)
ELEVENLABS_API_KEY=

# Daily.co (for video)
DAILY_API_KEY=

# Pinecone (for vector search)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ============================================
# HASHICORP VAULT (Secret Management)
# ============================================

# Vault endpoint
VAULT_ENDPOINT=http://127.0.0.1:8200

# Vault token (for initial setup - prefer AppRole for production)
VAULT_TOKEN=

# AppRole authentication (recommended for services)
VAULT_APPROLE_ROLE_ID=
VAULT_APPROLE_SECRET_ID=

# Vault paths
VAULT_SECRET_PREFIX=secret
VAULT_TRANSIT_MOUNT=transit
VAULT_DATABASE_MOUNT=database

# Cache settings (seconds)
VAULT_CACHE_TTL=3600

# ============================================
# DEPLOYMENT
# ============================================

NODE_ENV=development
LOG_LEVEL=info

# Service name (for logging)
SERVICE_NAME=rez-intelligence

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://rez.money

# Sentry (for error tracking)
SENTRY_DSN=

# ============================================
# PORTS (defaults)
# ============================================

# Phase 1
PORT_REORDER=4040
PORT_TASTE=4041
PORT_DEMAND=4042
PORT_PRICE=4043

# Phase 2
PORT_IDENTITY=4050
PORT_MEMORY=4051
PORT_AI_ROUTER=4052

# Phase 3
PORT_KNOWLEDGE=4060
PORT_MERCHANT_BRAIN=4061
PORT_AGENTS=4062

# Phase 4
PORT_PAYMENTS_BRAIN=4070
PORT_INVENTORY_SYNC=4071
PORT_CREATOR_NETWORK=4072
PORT_MERCHANT_OS=4073
