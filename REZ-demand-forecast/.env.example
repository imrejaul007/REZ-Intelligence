# Required Environment Variables for REZ Demand Forecast

# MongoDB Connection
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/rez_demand_forecast

# Redis Connection
REDIS_URL=redis://localhost:6379

# Internal Service Token (generate with: openssl rand -hex 32)
INTERNAL_SERVICE_TOKEN=change-me-to-secure-random-string

# Service Configuration
PORT=4042
NODE_ENV=development
LOG_LEVEL=info
SERVICE_NAME=rez-demand-forecast

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://rez.money

# Optional: Sentry for error tracking
SENTRY_DSN=
