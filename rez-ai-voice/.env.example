# ===========================================
# REZ AI Voice Agent Service - Environment
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ===========================================
# Twilio Configuration
# ===========================================
# Get these from https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_APPLICATION_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Voice Settings
TWILIO_RECORDING_ENABLED=true
TWILIO_TRANSCRIPTION_ENABLED=true
TWILIO_MAX_CALL_DURATION=14400

# Webhook URL (must be publicly accessible for Twilio)
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# ===========================================
# OpenAI Configuration (Whisper STT)
# ===========================================
# Get API key from https://platform.openai.com

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_WHISPER_LANGUAGE=en
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ===========================================
# ElevenLabs Configuration (TTS)
# ===========================================
# Get API key from https://elevenlabs.io

ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_SALES=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_SUPPORT=VR6AewLTigWG4xSOukaG
ELEVENLABS_VOICE_INFO=pFZP5JQG7iRYjFPEnMMb
ELEVENLABS_VOICE_MALE=ErXwobaYiN019PkyB4C9
ELEVENLABS_VOICE_FEMALE=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_monolingual_v1
ELEVENLABS_LATENCY=medium

# ===========================================
# Anthropic Configuration (Claude LLM)
# ===========================================
# Get API key from https://console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# ===========================================
# AI Settings
# ===========================================
AI_DEFAULT_LANGUAGE=en-US
AI_FALLBACKS_ENABLED=true

# ===========================================
# Transfer & Support Numbers
# ===========================================
OPERATOR_PHONE_NUMBER=+1234567890
SUPPORT_TRANSFER_NUMBER=+1234567890
SUPPORT_SUPERVISOR_NUMBER=+1234567890
TECH_SUPPORT_NUMBER=+1234567890

# ===========================================
# Rate Limiting
# ===========================================
MAX_TRANSCRIPTIONS_PER_MINUTE=60
MAX_SYNTHESES_PER_MINUTE=60
MAX_CALLS_PER_DAY=10000
MAX_CONCURRENT_CALLS=100

# ===========================================
# Storage & Logs
# ===========================================
TTS_OUTPUT_DIR=./audio_output
TTS_AUDIO_BASE_URL=https://your-domain.com/audio
TTS_MAX_FILE_AGE=3600
LOG_DIR=./logs
LOG_LEVEL=info

# ===========================================
# Security
# ===========================================
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com
