# REZ Orchestrator v2 Environment Variables

# Server Configuration
PORT=4006
NODE_ENV=development

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rez:orchestrator:v2:
REDIS_TTL_SECONDS=3600

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"orchestrator":"dev-token-orchestrator"}

# Agent Registry
AGENT_HEALTH_CHECK_INTERVAL_MS=30000
AGENT_HEALTH_CHECK_TIMEOUT_MS=5000
AGENT_MAX_RESPONSE_TIME_MS=30000
AGENT_FALLBACK_ENABLED=true

# Collaboration Settings
COLLABORATION_MAX_AGENTS=5
COLLABORATION_TIMEOUT_MS=60000
COLLABORATION_STRATEGY=sequential

# Escalation Settings
ESCALATION_ENABLED=true
ESCALATION_THRESHOLD_ATTEMPTS=3
ESCALATION_TIMEOUT_MS=120000
ESCALATION_WEBHOOK_URL=

# Response Time Tracking
RESPONSE_TIME_THRESHOLD_MS=5000
RESPONSE_TIME_ALERT_THRESHOLD_MS=10000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ROUTE=/health

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# Request Validation
MAX_REQUEST_SIZE=10mb
MAX_HEADERS_SIZE=8kb
