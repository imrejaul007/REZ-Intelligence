# REZ Orchestrator v2 - Environment Configuration
# Multi-agent orchestration engine with expert collaboration

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=4070
ORCHESTRATOR_PORT=4070
SERVICE_NAME=rez-orchestrator-v2
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_orchestrator_v2

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rez:orchestrator:v2:
REDIS_TTL_SECONDS=3600

# =============================================================================
# Service URLs
# =============================================================================
CORE_BRAIN_URL=http://localhost:4072
CONTEXT_ENGINE_URL=http://localhost:4071
AGENT_REGISTRY_URL=http://localhost:4073

# =============================================================================
# Timeout Configuration
# =============================================================================
EXPERT_TIMEOUT=5000
COLLABORATION_TIMEOUT=10000
HEALTH_CHECK_TIMEOUT=5000
MAX_RESPONSE_TIME_MS=30000

# =============================================================================
# Internal Service Authentication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-core-brain":"dev-token","rez-context-engine":"dev-token","rez-agent-registry":"dev-token"}

# =============================================================================
# Agent Registry Settings
# =============================================================================
AGENT_HEALTH_CHECK_INTERVAL_MS=30000
AGENT_HEALTH_CHECK_TIMEOUT_MS=5000
AGENT_MAX_RESPONSE_TIME_MS=30000
AGENT_FALLBACK_ENABLED=true

# =============================================================================
# Collaboration Settings
# =============================================================================
COLLABORATION_MAX_AGENTS=5
COLLABORATION_TIMEOUT_MS=60000
COLLABORATION_STRATEGY=sequential

# =============================================================================
# Escalation Settings
# =============================================================================
ESCALATION_ENABLED=true
ESCALATION_THRESHOLD_ATTEMPTS=3
ESCALATION_TIMEOUT_MS=120000
ESCALATION_WEBHOOK_URL=

# =============================================================================
# Response Time Tracking
# =============================================================================
RESPONSE_TIME_THRESHOLD_MS=5000
RESPONSE_TIME_ALERT_THRESHOLD_MS=10000

# =============================================================================
# Logging
# =============================================================================
LOG_FORMAT=json

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ROUTE=/health

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4072,http://localhost:4080

# =============================================================================
# Request Validation
# =============================================================================
MAX_REQUEST_SIZE=10mb
MAX_HEADERS_SIZE=8kb
