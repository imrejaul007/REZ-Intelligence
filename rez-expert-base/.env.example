# Service Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_expert_base

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rez:expert:base:

# Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"intent-service":"token","payment-service":"token"}

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Expert Configuration
EXPERT_NAME=base
EXPERT_VERSION=1.0.0
EXPERT_TONE=professional
EXPERT_EXPERTISE_LEVEL=intermediate

# Intent Service
INTENT_SERVICE_URL=http://localhost:4001
INTENT_API_KEY=your_intent_api_key

# Model Configuration
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-3-sonnet-20240229
MODEL_MAX_TOKENS=4096
MODEL_TEMPERATURE=0.7

# Knowledge Base
KNOWLEDGE_BASE_ENABLED=true
KNOWLEDGE_BASE_CACHE_TTL=3600

# Workflow Configuration
WORKFLOW_TIMEOUT_MS=30000
WORKFLOW_MAX_RETRIES=3

# Recommendation Engine
RECOMMENDATION_ENGINE_ENABLED=true
RECOMMENDATION_SIMILARITY_THRESHOLD=0.7
