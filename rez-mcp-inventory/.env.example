# =============================================================================
# REZ Inventory MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Inventory Service URL
INVENTORY_SERVICE_URL=http://localhost:4010

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real inventory service API calls
USE_REAL_INVENTORY=false
