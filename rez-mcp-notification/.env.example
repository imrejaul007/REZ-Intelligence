# =============================================================================
# REZ Notification Debugger MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Notification Service URL
NOTIFICATION_SERVICE_URL=http://localhost:4011

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real notification service API calls
USE_REAL_NOTIFICATION=false
