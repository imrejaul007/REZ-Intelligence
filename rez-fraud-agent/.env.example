# REZ Fraud Agent Environment Configuration

# Server Configuration
PORT=3007
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_fraud_agent
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Internal Service Authentication
INTERNAL_SERVICE_TOKENS_JSON={"payment-service":"token-here","wallet-service":"token-here","order-service":"token-here"}

# JWT Configuration
JWT_SECRET=your-jwt-secret-here

# Fraud Detection Thresholds
MAX_FAILED_ATTEMPTS=5
VELOCITY_WINDOW_SECONDS=300
VELOCITY_MAX_TRANSACTIONS=10
RISK_SCORE_THRESHOLD=75
HIGH_RISK_AMOUNT=10000

# Blacklist Expiry (seconds)
IP_BLACKLIST_TTL=86400
DEVICE_BLACKLIST_TTL=604800
ACCOUNT_BLACKLIST_TTL=2592000

# Alert Configuration
ALERT_WEBHOOK_URL=
ALERT_SLACK_WEBHOOK=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
