# REZ Core Brain - Environment Configuration
# Central orchestration engine for expert agents

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=development
PORT=4072
CORE_BRAIN_PORT=4072
SERVICE_NAME=rez-core-brain
LOG_LEVEL=info

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez_intelligence
MONGODB_DB=rez_core_brain

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# Memory Configuration
# =============================================================================
SHORT_TERM_MEMORY_TTL=3600
LONG_TERM_MEMORY_RETENTION=365
MAX_SHORT_TERM_MEMORIES=100
EMBEDDING_MODEL=text-embedding-ada-002

# =============================================================================
# Session Configuration
# =============================================================================
SESSION_TTL=1800
MAX_CONCURRENT_SESSIONS=10

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000

# =============================================================================
# Internal Service Communication
# =============================================================================
INTERNAL_SERVICE_TOKENS_JSON={"rez-orchestrator-v2":"dev-token","rez-context-engine":"dev-token","rez-agent-registry":"dev-token"}

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:4070,http://localhost:4071

# =============================================================================
# AI Configuration (Optional)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Health Check
# =============================================================================
HEALTH_CHECK_ROUTE=/health
