NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/rez-core-brain
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-jwt-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
INTERNAL_SERVICE_TOKENS_JSON={"rez-orchestrator":"orchestrator-token-123"}
CORS_ORIGINS=*
LOG_LEVEL=info
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
