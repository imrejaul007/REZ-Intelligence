# ============================================
# REZ WhatsApp Service - Environment Variables
# ============================================

# Server Configuration
PORT=4202
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-whatsapp

# Redis
REDIS_URL=redis://localhost:6379

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
WHATSAPP_PHONE_NUMBER=+14155238886
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
TWILIO_VERIFY_TOKEN=your_verify_token_here

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token
INTERNAL_SERVICE_TOKENS_JSON={"service-name":"token"}

# External Service URLs
PAYMENT_SERVICE_URL=http://localhost:4001
DELIVERY_SERVICE_URL=http://localhost:4009
USER_SERVICE_URL=http://localhost:4013

# Security
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
