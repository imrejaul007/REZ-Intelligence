# =============================================================================
# REZ Service Discovery MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# Set USE_REAL_SERVICES=true to connect to real REZ services

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real health checks (calls actual service endpoints)
REAL_HEALTH_CHECK=false

