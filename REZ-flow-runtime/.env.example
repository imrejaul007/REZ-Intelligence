# REZ Flow Runtime - Environment Variables
# Copy this file to .env and update values

# ==================== SERVER ====================
PORT=4200
NODE_ENV=development

# ==================== MONGODB ====================
MONGODB_URI=mongodb://localhost:27017/rez-flow-runtime

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== AUTHENTICATION ====================
# Internal service token for service-to-service auth
# IMPORTANT: Use a strong, unique token for each environment
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-here

# Comma-separated list of valid API keys for workflow builder
VALID_API_KEYS=key1,key2,key3

# Webhook signature verification secret
WEBHOOK_SECRET=your-webhook-secret-here

# ==================== RATE LIMITING ====================
# Time window in milliseconds
RATE_LIMIT_WINDOW=60000
# Max requests per window
RATE_LIMIT_MAX=1000

# ==================== WORKER ====================
# Worker concurrency level
WORKER_CONCURRENCY=5
# Worker name for logging
WORKER_NAME=execution-worker

# ==================== LOGGING ====================
LOG_LEVEL=info

# ==================== ALLOWED ORIGINS ====================
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ==================== RABTUL SERVICES (Core Platform) ====================
# These services handle all notifications, wallet, orders, and profiles

# RABTUL Notify Service (Port 4011)
# Handles: SMS, Push Notifications, Email
NOTIFY_SERVICE_URL=http://localhost:4011

# RABTUL Auth Service (Port 4002)
# Handles: JWT verification, OTP, user sessions
AUTH_SERVICE_URL=http://localhost:4002

# RABTUL Payment Service (Port 4001)
# Handles: Razorpay payments, UPI, webhooks
PAYMENT_SERVICE_URL=http://localhost:4001

# RABTUL Wallet Service (Port 4004)
# Handles: Coin balance, add/deduct coins, loyalty
WALLET_SERVICE_URL=http://localhost:4004

# RABTUL Order Service (Port 4006)
# Handles: Order creation, status updates, fulfillment
ORDER_SERVICE_URL=http://localhost:4006

# RABTUL Profile Service (Port 4013)
# Handles: User profiles, preferences, attributes
PROFILE_SERVICE_URL=http://localhost:4013

# ==================== EXTERNAL SERVICES ====================

# Unified WhatsApp Service (Port 4202)
# Handles: WhatsApp Business API integration
WHATSAPP_SERVICE_URL=http://localhost:4202

# REZ Intelligence (Port 4018)
# Handles: AI predictions, recommendations, intent
REZ_INTELLIGENCE_URL=http://localhost:4018
REZ_INTELLIGENCE_API_KEY=your-api-key

# ==================== RETRY SETTINGS ====================
# Max retries for service calls (default: 3)
SERVICE_MAX_RETRIES=3
# Initial retry delay in ms (default: 1000)
SERVICE_RETRY_INITIAL_DELAY=1000
# Max retry delay in ms (default: 30000)
SERVICE_RETRY_MAX_DELAY=30000
# Backoff multiplier (default: 2)
SERVICE_RETRY_BACKOFF_MULTIPLIER=2
# Request timeout in ms (default: 30000)
SERVICE_REQUEST_TIMEOUT=30000

# ==================== DLQ SETTINGS ====================
DLQ_MAX_RETRIES=5
DLQ_RETRY_DELAY=60000
DLQ_TTL=604800000
DLQ_CLEANUP_INTERVAL=3600000

# ==================== EXECUTION SETTINGS ====================
# Max concurrent nodes per execution
MAX_CONCURRENT_NODES=5
# Default node timeout (ms)
DEFAULT_NODE_TIMEOUT=30000
# Max retries per node
DEFAULT_MAX_RETRIES=3

# ==================== CLEANUP ====================
# Execution retention in days (0 = no cleanup)
EXECUTION_RETENTION_DAYS=90
