# REZ Flow Runtime - Environment Variables
# Copy this file to .env and update values

# ==================== SERVER ====================
PORT=4200
NODE_ENV=development

# ==================== MONGODB ====================
MONGODB_URI=mongodb://localhost:27017/rez-flow-runtime

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== AUTHENTICATION ====================
# Internal service token for service-to-service auth
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-here

# Comma-separated list of valid API keys for workflow builder
VALID_API_KEYS=key1,key2,key3

# Webhook signature verification secret
WEBHOOK_SECRET=your-webhook-secret-here

# ==================== RATE LIMITING ====================
# Time window in milliseconds
RATE_LIMIT_WINDOW=60000
# Max requests per window
RATE_LIMIT_MAX=1000

# ==================== WORKER ====================
# Worker concurrency level
WORKER_CONCURRENCY=5
# Worker name for logging
WORKER_NAME=execution-worker

# ==================== LOGGING ====================
LOG_LEVEL=info

# ==================== ALLOWED ORIGINS ====================
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ==================== EXTERNAL SERVICES ====================
# Email service (for send_email action)
# EMAIL_API_KEY=your-email-api-key
# EMAIL_FROM_ADDRESS=noreply@rez.money

# SMS service (for send_sms action)
# SMS_API_KEY=your-sms-api-key
# SMS_PROVIDER=twilio

# WhatsApp service
# WHATSAPP_API_KEY=your-whatsapp-api-key

# Push notification service (for send_push action)
# PUSH_SERVICE=expo
# PUSH_API_KEY=your-push-api-key

# ==================== INTEGRATION URLs ====================
# RABTUL Services
AUTH_SERVICE_URL=http://localhost:4002
PAYMENT_SERVICE_URL=http://localhost:4001
WALLET_SERVICE_URL=http://localhost:4004
NOTIFICATION_SERVICE_URL=http://localhost:4011
ORDER_SERVICE_URL=http://localhost:4006

# REZ Intelligence
REZ_INTELLIGENCE_URL=http://localhost:4018
REZ_INTELLIGENCE_API_KEY=your-api-key

# ==================== DLQ SETTINGS ====================
DLQ_MAX_RETRIES=5
DLQ_RETRY_DELAY=60000
DLQ_TTL=604800000
DLQ_CLEANUP_INTERVAL=3600000

# ==================== EXECUTION SETTINGS ====================
# Max concurrent nodes per execution
MAX_CONCURRENT_NODES=5
# Default node timeout (ms)
DEFAULT_NODE_TIMEOUT=30000
# Max retries per node
DEFAULT_MAX_RETRIES=3

# ==================== CLEANUP ====================
# Execution retention in days (0 = no cleanup)
EXECUTION_RETENTION_DAYS=90
