KB_SERVICE_URL=http://localhost:4005

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Option 1: IMAP Polling (Gmail, Outlook, etc.)
EMAIL_POLL_ENABLED=true
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=support@yourdomain.com
EMAIL_IMAP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_POLL_INTERVAL=60000

# Option 2: Use webhooks instead (no polling needed)
# - SendGrid: Set up Inbound Parse in dashboard
# - AWS SES: Use Lambda + webhook
# - Mailgun: Configure routes in dashboard

# Email sending (for auto-responses)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=support@yourdomain.com
EMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=support@yourdomain.com

# WhatsApp Business API (when ready)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Sentry (optional)
SENTRY_DSN=
