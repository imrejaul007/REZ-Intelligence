# =============================================================================
# REZ Payment Debugger MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Payment Service URL
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real payment service API calls
USE_REAL_PAYMENT=false
