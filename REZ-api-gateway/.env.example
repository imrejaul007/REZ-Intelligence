# REZ Intelligence Gateway Configuration

# Service Port
PORT=4200
NODE_ENV=development

# CORS
CORS_ORIGINS=http://localhost:3000,https://rez.example.com

# Internal Service Token (for service-to-service auth)
INTERNAL_SERVICE_TOKEN=rez-internal-token-change-in-production

# REZ Intelligence Services URLs
REZ_MEMORY_URL=http://localhost:4201
REZ_FLOW_URL=http://localhost:4200
REZ_INTENT_URL=http://localhost:4018
REZ_CARE_URL=http://localhost:4058
REZ_PREDICTIVE_URL=http://localhost:4141
REZ_WHATSAPP_URL=http://localhost:4202

# Logging
LOG_LEVEL=info
