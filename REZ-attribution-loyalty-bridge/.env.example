# Service Configuration
SERVICE_NAME=rez-attribution-loyalty-bridge
PORT=4040
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-attribution-loyalty-bridge

# Redis
REDIS_URL=redis://localhost:6379

# Service URLs
ATTRIBUTION_SERVICE_URL=http://localhost:4090
LOYALTY_SERVICE_URL=http://localhost:4002
WALLET_SERVICE_URL=http://localhost:4004
REWARDS_SERVICE_URL=http://localhost:4008
NOTIFICATION_SERVICE_URL=http://localhost:4004

# Internal Token (for service-to-service auth)
INTERNAL_SERVICE_TOKEN=your-secure-token-here

# RabbitMQ (optional - for message queue)
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=attribution-loyalty-bridge

# Campaign Multipliers (JSON)
CAMPAIGN_MULTIPLIERS_JSON={"summer_sale":1.5,"holiday":2.0,"new_user":1.25}

# Channel Base Rewards (JSON - coins per 100 INR)
CHANNEL_BASE_REWARDS_JSON={"dooh":3,"qr":2,"search":1.5,"social":1.5,"email":1,"sms":1,"referral":3,"creator":2.5,"organic":1,"direct":0.5}

# DOOH Bonus (extra coins for DOOH attribution)
DOOH_BONUS_MULTIPLIER=1.5

# Maximum cashback percentage
MAX_CASHBACK_PERCENT=10

# Conversion window in hours
CONVERSION_WINDOW_HOURS=168
