# REZ Merchant 360 Environment Configuration

# Server
PORT=4000
NODE_ENV=development

# GraphQL
GRAPHQL_PATH=/graphql
PLAYGROUND_PATH=/playground

# Services
FINANCE_SERVICE_URL=http://localhost:4001
CATALOG_SERVICE_URL=http://localhost:4002
INVENTORY_SERVICE_URL=http://localhost:4003
CRM_SERVICE_URL=http://localhost:4004
LOYALTY_SERVICE_URL=http://localhost:4005
STAFF_SERVICE_URL=http://localhost:4006
COMPLIANCE_SERVICE_URL=http://localhost:4007
ANALYTICS_SERVICE_URL=http://localhost:4008
MEMORY_SERVICE_URL=http://localhost:4009

# AgentDB (AI Memory)
AGENTDB_HOST=localhost
AGENTDB_PORT=8080
AGENTDB_DATABASE=merchant_360

# Redis (Cache)
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Identity Resolution
IDENTITY_MATCH_THRESHOLD=0.85
IDENTITY_DEDUP_WINDOW_HOURS=24

# Cross-Platform Sync
SYNC_INTERVAL_MS=60000
SYNC_RETRY_ATTEMPTS=3
SYNC_BATCH_SIZE=100

# Health Check
HEALTH_CHECK_INTERVAL_MS=30000
