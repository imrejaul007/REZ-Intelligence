# =============================================================================
# REZ Event Bus MCP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# Event Bus URL
EVENT_BUS_URL=http://localhost:4031

# Internal Service Token (required for real API calls)
INTERNAL_SERVICE_TOKEN=your-internal-token-here

# Enable real event bus API calls
USE_REAL_EVENT_BUS=false
