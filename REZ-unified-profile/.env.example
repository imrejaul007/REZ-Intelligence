# REZ Unified Profile Service Configuration

# Server
PORT=4060
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-unified-profile

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=your-secret-token-here
INTERNAL_SERVICE_TOKENS_JSON={}

# Signal Services URLs
LOCATION_SERVICE_URL=http://localhost:4115
BEHAVIORAL_SERVICE_URL=http://localhost:4110
SOCIAL_SERVICE_URL=http://localhost:4116
COMPETITOR_SERVICE_URL=http://localhost:4117
IDENTITY_SERVICE_URL=http://localhost:4001
CDP_SERVICE_URL=http://localhost:4025

# Logging
LOG_LEVEL=info
