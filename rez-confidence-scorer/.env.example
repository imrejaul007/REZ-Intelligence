# REZ Confidence Scorer - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Application
# ============================================
APP_NAME=rez-confidence-scorer
PORT=4081
NODE_ENV=development
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=rez_confidence
MONGODB_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_IDLE_MS=30000
MONGODB_RETRY_WRITES=true
MONGODB_RETRY_READS=true

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rez:confidence:
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=1000

# ============================================
# Authentication
# ============================================
# JSON map of service tokens for internal service-to-service auth
# Format: {"service-name":"token"}
INTERNAL_SERVICE_TOKENS_JSON={"rez-orchestrator":"token123","rez-payment":"token456"}
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# Scoring Configuration
# ============================================
# Confidence weights (must sum to 1.0)
WEIGHT_INTENT_MATCH=0.35
WEIGHT_CONTEXT_RELEVANCE=0.30
WEIGHT_HISTORY_ACCURACY=0.25
WEIGHT_LOAD_FACTOR=0.10

# Cache configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=10000

# Score thresholds
MIN_SCORE_THRESHOLD=0.1
HIGH_CONFIDENCE_THRESHOLD=0.75
LOW_CONFIDENCE_THRESHOLD=0.4

# Limits
MAX_AGENTS_PER_REQUEST=50
MAX_HISTORY_ENTRIES=1000
MAX_PROCESSING_TIME_MS=500

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Metrics
# ============================================
METRICS_ENABLED=true
METRICS_RETENTION_DAYS=30
