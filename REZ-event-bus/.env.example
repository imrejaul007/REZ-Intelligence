# Server Configuration
PORT=4082
NODE_ENV=development

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rez:event-bus:

# Kafka Configuration
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=rez-event-bus
KAFKA_GROUP_ID=rez-event-bus-group
KAFKA_SESSION_TIMEOUT=30000
KAFKA_HEARTBEAT_INTERVAL=3000

# Authentication
INTERNAL_SERVICE_TOKENS_JSON={"payment-service":"token1","wallet-service":"token2","order-service":"token3"}

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Event Bus Settings
EVENT_RETENTION_HOURS=168
MAX_EVENT_PAYLOAD_SIZE=1048576
MAX_SUBSCRIPTIONS_PER_CLIENT=100

# Health Check
HEALTH_CHECK_INTERVAL=30000
