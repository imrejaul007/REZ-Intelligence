# REZ Memory Layer Environment Configuration
# Copy to .env and configure values

# Server Configuration
PORT=4201
NODE_ENV=development

# REZ Event Bus Connection
REZ_EVENT_BUS_URL=http://localhost:4025
REZ_EVENT_BUS_API_KEY=your-event-bus-api-key

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rez:memory:

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_memory_layer

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# Cache TTL Configuration (in seconds)
TIMELINE_CACHE_TTL=86400
SEGMENTS_CACHE_TTL=3600
PREFERENCES_CACHE_TTL=1800

# Enrichment Service URLs
REZ_INTELLIGENCE_URL=http://localhost:4018
REZ_PLATFORM_URL=http://localhost:4000
CATALOG_SERVICE_URL=http://localhost:4007
MERCHANT_SERVICE_URL=http://localhost:4005

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL=info
